# Nginx vhost — {{ item.name }} protected by Authelia TOTP
# Managed by Ansible (setup-lxc-2fa-master.yml). Do not edit manually.
#
# https://{{ item.hostname }}.{{ authelia_domain }} → {{ item.backend }}

server {
    listen 443 ssl;
    server_name {{ item.hostname }}.{{ authelia_domain }};

    ssl_certificate     {{ authelia_tls_dir }}/authelia.crt;
    ssl_certificate_key {{ authelia_tls_dir }}/authelia.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    # ------------------------------------------------------------------ #
    # Authelia forward-auth endpoint (internal — called by auth_request)  #
    # ------------------------------------------------------------------ #
    location /internal/authelia/authz {
        internal;
        proxy_pass              http://127.0.0.1:9091/api/authz/auth-request;
        proxy_pass_request_body off;
        proxy_set_header        Content-Length      "";
        proxy_set_header        X-Forwarded-For     $proxy_add_x_forwarded_for;
        proxy_set_header        X-Forwarded-Host    $http_host;
        proxy_set_header        X-Forwarded-Proto   $scheme;
        proxy_set_header        X-Original-URL      $scheme://$http_host$request_uri;
    }

    # ------------------------------------------------------------------ #
    # Proxied service — gated behind TOTP                                 #
    # ------------------------------------------------------------------ #
    location / {
        # Every request must pass the Authelia TOTP check first.
        auth_request /internal/authelia/authz;

        # Capture the redirect target so Authelia can send the user back after login.
        auth_request_set $target_url $scheme://$http_host$request_uri;

        # Forward the authenticated user identity to the backend.
        auth_request_set $user   $upstream_http_remote_user;
        auth_request_set $groups $upstream_http_remote_groups;
        auth_request_set $name   $upstream_http_remote_name;

        # Redirect unauthenticated requests to the Authelia portal.
        error_page 401 =302 https://{{ authelia_auth_hostname }}.{{ authelia_domain }}/?rd=$target_url;

        proxy_set_header Remote-User   $user;
        proxy_set_header Remote-Groups $groups;
        proxy_set_header Remote-Name   $name;

        # ---- Upstream proxy ------------------------------------------ #
        proxy_pass         {{ item.backend }};
        proxy_set_header   Host              $http_host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_read_timeout 90s;
        proxy_send_timeout 90s;
{% if not (item.backend_ssl_verify | default(true)) %}
        # Backend uses a self-signed certificate — skip verification.
        proxy_ssl_verify   off;
{% endif %}
    }
}

server {
    listen 80;
    server_name {{ item.hostname }}.{{ authelia_domain }};
    return 301 https://$host$request_uri;
}
