---
# Authelia configuration — managed by Ansible (setup-lxc-2fa-master.yml)
# Do not edit manually; changes will be overwritten on next playbook run.

theme: 'light'

server:
  address: 'tcp://127.0.0.1:9091/'

log:
  level: 'info'
  format: 'text'
  file_path: '{{ authelia_log_dir }}/authelia.log'
  keep_stdout: false

totp:
  issuer: '{{ authelia_totp_issuer }}'
  algorithm: 'sha1'
  digits: 6
  period: 30
  skew: 1
  secret_size: 32

authentication_backend:
  file:
    path: '{{ authelia_config_dir }}/users_database.yml'
    watch: true
    password:
      algorithm: argon2id
      iterations: 1
      salt_length: 16
      parallelism: 8
      memory: 64

access_control:
  # Deny everything by default — only explicitly listed domains get through.
  default_policy: deny
  rules:
    # Require two-factor (TOTP) for all protected services.
    - domain:
{% for svc in authelia_services %}
        - '{{ svc.hostname }}.{{ authelia_domain }}'
{% endfor %}
      policy: two_factor

session:
  secret: '{{ vault_authelia_session_secret }}'
  cookies:
    - name: 'authelia_session'
      domain: '{{ authelia_domain }}'
      authelia_url: 'https://{{ authelia_auth_hostname }}.{{ authelia_domain }}'
      expiration: '1h'
      inactivity: '5m'
      remember_me: '1M'

regulation:
  # Lock account after 5 failed attempts within 2 minutes for 5 minutes.
  max_retries: 5
  find_time: '2m'
  ban_time: '5m'

storage:
  encryption_key: '{{ vault_authelia_storage_encryption_key }}'
  local:
    path: '{{ authelia_data_dir }}/db.sqlite3'

notifier:
  # No SMTP — TOTP registration link is written to a local file instead.
  # View with: cat {{ authelia_log_dir }}/notification.txt
  disable_startup_check: true
  filesystem:
    filename: '{{ authelia_log_dir }}/notification.txt'

identity_validation:
  reset_password:
    jwt_secret: '{{ vault_authelia_jwt_secret }}'
